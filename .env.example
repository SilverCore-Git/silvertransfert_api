# Server Configuration
HOSTNAME=localhost
PORT=8080

# Directory Configuration
DATA_DIR=data
TEMP_DIR=temp
LOG_DIR=log
DB_FILE=db/database.json
BACKUP_DATA_DIR=mirror

# Backup Configuration
BACKUP=false

# Encryption Configuration
MAX_BYTE_FOR_KEY=256
EXPIRE_TIME=30

# Security Configuration - REQUIRED
# Text encryption key (must be at least 32 characters with good entropy)
TEXT_SECRET_KEY=your_super_secret_key_with_at_least_32_characters_and_good_entropy

# Discord webhook for notifications - REQUIRED
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_url
